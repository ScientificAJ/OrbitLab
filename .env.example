# Backend
DATABASE_URL=sqlite:///./.orbitlab/orbitlab.db
REDIS_URL=redis://127.0.0.1:6379/0
ORBITLAB_RUN_JOBS_INLINE=1
ORBITLAB_MAST_CACHE_DIR=.orbitlab/mast
ORBITLAB_MODEL_REGISTRY=.orbitlab/models.json

# Local dev server ports
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

# Kepler/K1 TensorFlow runtime for the registered checkpoint path
ORBITLAB_KEPLER_TF_IMAGE=tensorflow/tensorflow:1.5.0-py3

# K2 ML uses the registered ExoMAC-KKT bundle fetched by scripts/fetch_k2_exomac_kkt.py.

# Optional external AstroNet-compatible override
# ORBITLAB_ASTRONET_MODEL_PATH=/absolute/path/to/saved_model_or_onnx
# ORBITLAB_ASTRONET_MODEL_SHA256=<sha256>
# ORBITLAB_ASTRONET_MODEL_SOURCE=Google Research exoplanet-ml / AstroNet
# ORBITLAB_ASTRONET_MODEL_VERSION=external
